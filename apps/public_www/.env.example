# Public Website environment template
#
# Copy to `.env.local` for local development. Production values are sourced
# from the GitHub Environment (`production`/`staging`) variables/secrets in
# .github/workflows/{deploy,promote}-public-www.yml.

# Absolute origin the site is served from. Used by canonical URLs, sitemap,
# robots, and structured data. Localhost is allowed in dev only.
NEXT_PUBLIC_SITE_ORIGIN=http://localhost:3000

# Brand-level settings reused across copy and metadata.
NEXT_PUBLIC_SITE_NAME=Siu Tin Dei
NEXT_PUBLIC_SITE_TAGLINE=Curated children's activities in Hong Kong.

# Optional contact links shown in the footer.
NEXT_PUBLIC_EMAIL=hello@lx-software.com
NEXT_PUBLIC_WHATSAPP_URL=
NEXT_PUBLIC_INSTAGRAM_URL=

# When the staging CloudFront alias serves the site, the deploy script forces
# a deny-all robots.txt and the CloudFront response headers policy adds an
# X-Robots-Tag noindex header. The badge below is purely cosmetic.
NEXT_PUBLIC_STAGING_BADGE_ENABLED=false
